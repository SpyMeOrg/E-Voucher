# إعدادات البريد الإلكتروني (IMAP)
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_HOST=imap.example.com
EMAIL_PORT=993
EMAIL_TLS=true

# إعدادات الواتساب
WHATSAPP_ENABLED=true
WHATSAPP_STATUS_NOTIFY=true

# إعدادات الخادم
SERVER_PORT=3001
NODE_ENV=production

# إعدادات تخزين البيانات
DATA_DIRECTORY=/home/voo-app/voo-order-tracker/data

# إعدادات تتبع الأوردرات
ORDER_SENDER_EMAIL=no-reply@voopayment.com
ORDER_CHECK_INTERVAL=60000
VODAFONE_FEE=1
OTHER_OPERATORS_FEE_PERCENT=0.5
MAX_FEE=15

# إعدادات الأمان
JWT_SECRET=change-this-to-a-secure-random-string
SESSION_SECRET=change-this-to-another-secure-random-string 